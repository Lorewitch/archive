# Normalize text files so generated output stays stable across systems.
* text=auto eol=lf

*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.py text eol=lf
*.md text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.txt text eol=lf

# Binary assets.
*.webp binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
