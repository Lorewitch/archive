  "materials": [
    {
      "key": "damaged_mask",
      "title": {
        "ru": "Разбитая маска",
        "en": "Damaged Mask",
        "zh": "破损的面具"
      },
      "icon": "assets/icons/items/common_enemies/damaged_mask.webp",
      "text": {
        "ru": "Разбитая костяная маска, давным-давно принадлежавшая какому-то хиличурлу. Разбита на мелкие осколки, поэтому не может выполнять свою основную функцию.",
        "en": "A broken bone mask that once belonged to some hilichurl.\nNow more broken than complete, it can no longer perform its primary function.",
        "zh": "破碎的骨质面具，曾经属于某个丘丘人。\n破损的部分比完整的部分更多，已经失去了假面应有的功能。"
      }
    },
    {
      "key": "stained_mask",
      "title": {
        "ru": "Грязная маска",
        "en": "Stained Mask",
        "zh": "污秽的面具"
      },
      "icon": "assets/icons/items/common_enemies/stained_mask.webp",
      "text": {
        "ru": "Костяная маска со слабым запахом, покрытая странными пятнами.\nХоть и предназначена для лица, но только хиличурл может носить подобное.",
        "en": "A bone mask, covered in unidentifiable stains, that emanates a mysterious odor.\nYet such is the devotion of hilichurls to masks that they will wear it nonetheless.",
        "zh": "沾满了难以辨认的污渍，散发着微妙气味的骨质面具。\n即使这样也要戴在脸上，这就是丘丘人的执着。"
      }
    },
    {
      "key": "ominous_mask",
      "title": {
        "ru": "Зловещая маска",
        "en": "Ominous Mask",
        "zh": "不祥的面具"
      },
      "icon": "assets/icons/items/common_enemies/ominous_mask.webp",
      "text": {
        "ru": "Покрытая узором костяная маска, предназначенная для запугивания врагов.\nНикто не знает, почему хиличурлы никогда не снимают свои маски. Есть версия, что они просто боятся своего отражения в воде.",
        "en": "A glossy bone mask with oil markings painted on it, meant to intimidate enemies.\nNo one really knows why hilichurls are so fascinated with masks. Some say that it's because they don't want to see their own reflections in the water.",
        "zh": "光亮的骨质面具，上面涂绘着意在恐吓敌人的油彩。\n丘丘人对面具的执着缘起为何，至今无人能解。一说认为是不愿看见自己在水中的倒影。"
      }
    }
  ],
  "material_count": 3
}